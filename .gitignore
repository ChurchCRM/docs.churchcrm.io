# Dependencies
node_modules/

# Docusaurus build output and cache
build/
.docusaurus/
.cache-loader/

# Generated API docs — regenerated by deploy workflow from CRM openapi specs.
# Run `npm run regen` locally before `npm start` after a fresh clone.
# index.md files are hand-written overviews; kept via negation patterns.
docs/api/public/*
!docs/api/public/index.md
docs/api/private/*
!docs/api/private/index.md

# OpenAPI specs — downloaded fresh from CRM master on every deploy.
# Copy manually from CRM/openapi/ for local dev.
openapi/

# macOS
.DS_Store
**/.DS_Store

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor directories
.vscode/
.idea/
*.swp
*.swo
